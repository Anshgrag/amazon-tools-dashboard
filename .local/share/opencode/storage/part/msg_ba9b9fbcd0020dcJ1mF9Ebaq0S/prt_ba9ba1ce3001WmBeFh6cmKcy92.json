      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>EcoTrack - Test</title>\n    <link rel=\"stylesheet\" href=\"style.css\">\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n</head>\n<body style=\"background: var(--bg-primary);\">\n    <div class=\"app-container\">\n        <main class=\"main-content\">\n            <div class=\"card\">\n                <h3 class=\"card-title\">SMART SAVINGS MONITOR</h3>\n                <div class=\"savings-summary\">\n                    <div class=\"savings-row\">\n                        <div class=\"savings-item waste\">\n                            <div class=\"savings-label\">Wasted Today</div>\n                            <div class=\"savings-amount\" id=\"wastedAmount\">Loading...</div>\n                            <div class=\"savings-desc\">Without automation</div>\n                        </div>\n                        <div class=\"savings-divider\"></div>\n                        <div class=\"savings-item saved\">\n                            <div class=\"savings-label\">Saved Today</div>\n                            <div class=\"savings-amount\" id=\"savedAmount\">Loading...</div>\n                            <div class=\"savings-desc\">With automation</div>\n                        </div>\n                    </div>\n                    <div class=\"net-savings\">\n                        <div class=\"net-label\">Net Savings</div>\n                        <div class=\"net-amount\" id=\"netSavings\">Loading...</div>\n                        <div class=\"net-percentage\" id=\"savingsPercentage\">Loading...</div>\n                    </div>\n                </div>\n                <div class=\"chart-container\">\n                    <canvas id=\"savingsChart\"></canvas>\n                </div>\n                <div class=\"device-savings-list\" id=\"deviceSavingsList\">\n                    <p>Loading devices...</p>\n                </div>\n            </div>\n        </main>\n    </div>\n\n    <script>\n        // Direct test script\n        console.log('=== DIRECT TEST START ===');\n        \n        function formatCurrency(value) {\n            return `$${parseFloat(value).toFixed(2)}`;\n        }\n        \n        async function loadData() {\n            try {\n                console.log('Fetching data...');\n                const response = await fetch('http://localhost:5000/api/savings');\n                console.log('Response status:', response.status);\n                \n                if (!response.ok) throw new Error(`HTTP ${response.status}`);\n                \n                const result = await response.json();\n                console.log('Data received:', result);\n                \n                if (result.status !== 'success') throw new Error('API error');\n                \n                const data = result.data;\n                \n                // Update display\n                document.getElementById('wastedAmount').textContent = formatCurrency(data.total_waste_cost);\n                document.getElementById('savedAmount').textContent = formatCurrency(data.total_saved_cost);\n                document.getElementById('netSavings').textContent = formatCurrency(data.net_savings);\n                \n                const percentage = ((data.total_saved_cost / (data.total_waste_cost + data.total_saved_cost)) * 100);\n                document.getElementById('savingsPercentage').textContent = percentage.toFixed(1) + '%';\n                \n                console.log('Display updated successfully');\n                \n            } catch (error) {\n                console.error('Error:', error);\n                document.getElementById('wastedAmount').textContent = 'ERROR';\n                document.getElementById('savedAmount').textContent = 'ERROR';\n                document.getElementById('netSavings').textContent = 'ERROR';\n            }\n        }\n        \n        // Load data immediately\n        loadData();\n        \n        // Refresh every 30 seconds\n        setInterval(loadData, 30000);\n        \n    </script>\n</body>\n</html>",
