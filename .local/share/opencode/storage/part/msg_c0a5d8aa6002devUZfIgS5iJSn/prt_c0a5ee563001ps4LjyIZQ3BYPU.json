    "input": {
      "content": "import React from 'react';\nimport { Eye, Camera, Shield, Users, Clock, CheckCircle } from 'lucide-react';\nimport { useRouter } from 'next/router';\nimport { useAuth } from '../hooks/useAuth';\n\nexport const WelcomeScreen: React.FC = () => {\n  const router = useRouter();\n  const { user } = useAuth();\n\n  const handleGetStarted = () => {\n    if (user) {\n      router.push('/scan');\n    } else {\n      router.push('/auth');\n    }\n  };\n\n  return (\n    <div className=\"max-w-6xl mx-auto\">\n      {/* Hero Section */}\n      <div className=\"text-center mb-16\">\n        <div className=\"flex justify-center mb-6\">\n          <div className=\"p-4 bg-blue-600 rounded-full\">\n            <Eye className=\"w-16 h-16 text-white\" />\n          </div>\n        </div>\n        \n        <h1 className=\"text-5xl font-bold text-gray-900 mb-6\">\n          AI-Powered Eye Disease\n          <span className=\"text-blue-600\"> Detection</span>\n        </h1>\n        \n        <p className=\"text-xl text-gray-600 mb-8 max-w-3xl mx-auto\">\n          Advanced artificial intelligence for early eye disease detection. \n          Upload an eye image for instant AI analysis and screening.\n        </p>\n        \n        <div className=\"bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-8 max-w-2xl mx-auto\">\n          <p className=\"text-sm text-yellow-800\">\n            <strong>Medical Disclaimer:</strong> This application is for educational and screening purposes only \n            and is NOT a replacement for professional medical diagnosis. Always consult with qualified \n            healthcare professionals for medical decisions.\n          </p>\n        </div>\n        \n        <button\n          onClick={handleGetStarted}\n          className=\"bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-700 transition-colors inline-flex items-center gap-2\"\n        >\n          <Camera className=\"w-5 h-5\" />\n          Get Started\n        </button>\n      </div>\n\n      {/* Features Grid */}\n      <div className=\"grid md:grid-cols-3 gap-8 mb-16\">\n        <div className=\"bg-white p-6 rounded-xl shadow-lg\">\n          <div className=\"flex items-center mb-4\">\n            <div className=\"p-2 bg-blue-100 rounded-lg\">\n              <Eye className=\"w-6 h-6 text-blue-600\" />\n            </div>\n            <h3 className=\"text-xl font-semibold ml-3\">AI Analysis</h3>\n          </div>\n          <p className=\"text-gray-600\">\n            Advanced deep learning models analyze eye images for multiple conditions \n            with high accuracy and confidence scoring.\n          </p>\n        </div>\n\n        <div className=\"bg-white p-6 rounded-xl shadow-lg\">\n          <div className=\"flex items-center mb-4\">\n            <div className=\"p-2 bg-green-100 rounded-lg\">\n              <Clock className=\"w-6 h-6 text-green-600\" />\n            </div>\n            <h3 className=\"text-xl font-semibold ml-3\">Fast Results</h3>\n          </div>\n          <p className=\"text-gray-600\">\n            Get AI-powered screening results in under 2 seconds with detailed \n            explanations and confidence scores.\n          </p>\n        </div>\n\n        <div className=\"bg-white p-6 rounded-xl shadow-lg\">\n          <div className=\"flex items-center mb-4\">\n            <div className=\"p-2 bg-purple-100 rounded-lg\">\n              <Shield className=\"w-6 h-6 text-purple-600\" />\n            </div>\n            <h3 className=\"text-xl font-semibold ml-3\">Privacy First</h3>\n          </div>\n          <p className=\"text-gray-600\">\n            Your health data is encrypted and protected. We prioritize your privacy \n            and follow medical data protection standards.\n          </p>\n        </div>\n      </div>\n\n      {/* Supported Conditions */}\n      <div className=\"bg-white rounded-xl shadow-lg p-8 mb-16\">\n        <h2 className=\"text-3xl font-bold text-center mb-8\">Detectable Conditions</h2>\n        \n        <div className=\"grid md:grid-cols-2 lg:grid-cols-4 gap-4\">\n          {[\n            'Conjunctivitis',\n            'Stye',\n            'Cataract',\n            'Blepharitis',\n            'Corneal Ulcer',\n            'Dry Eye',\n            'Red Eye',\n            'Glaucoma Indicators'\n          ].map((condition, index) => (\n            <div key={index} className=\"flex items-center space-x-2\">\n              <CheckCircle className=\"w-5 h-5 text-green-500\" />\n              <span className=\"text-gray-700\">{condition}</span>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* How It Works */}\n      <div className=\"text-center mb-16\">\n        <h2 className=\"text-3xl font-bold mb-8\">How It Works</h2>\n        \n        <div className=\"grid md:grid-cols-4 gap-8\">\n          {[\n            { step: 1, title: 'Upload Image', desc: 'Capture or upload a clear eye image' },\n            { step: 2, title: 'AI Analysis', desc: 'Our AI model analyzes the image instantly' },\n            { step: 3, title: 'Get Results', desc: 'Receive detailed analysis with confidence scores' },\n            { step: 4, title: 'Track History', desc: 'Monitor your scan history over time' }\n          ].map((item) => (\n            <div key={item.step} className=\"text-center\">\n              <div className=\"w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-lg font-bold\">\n                {item.step}\n              </div>\n              <h3 className=\"font-semibold mb-2\">{item.title}</h3>\n              <p className=\"text-gray-600 text-sm\">{item.desc}</p>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Call to Action */}\n      <div className=\"text-center bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl p-8 text-white\">\n        <h2 className=\"text-3xl font-bold mb-4\">Start Your Eye Health Screening Today</h2>\n        <p className=\"mb-6 opacity-90\">\n          Join thousands of users using AI for early eye disease detection\n        </p>\n        <button\n          onClick={handleGetStarted}\n          className=\"bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors\"\n        >\n          Start Screening Now\n        </button>\n      </div>\n    </div>\n  );\n};",
