      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>EcoTrack Test</title>\n    <style>\n        :root {\n            --bg-primary: #1a2332;\n            --bg-card: #2a3f5f;\n            --text-primary: #ffffff;\n            --text-secondary: #b0c4de;\n            --accent-red: #ff4757;\n            --accent-green: #06ffa5;\n            --accent-teal: #4ecdc4;\n        }\n        \n        body {\n            background: var(--bg-primary);\n            color: var(--text-primary);\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            margin: 20px;\n        }\n        \n        .card {\n            background: var(--bg-card);\n            border-radius: 15px;\n            padding: 25px;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);\n            max-width: 600px;\n            margin: 20px auto;\n        }\n        \n        .card-title {\n            font-size: 0.85em;\n            font-weight: 600;\n            color: var(--text-secondary);\n            letter-spacing: 1px;\n            margin-bottom: 20px;\n            text-transform: uppercase;\n        }\n        \n        .savings-row {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 20px;\n        }\n        \n        .savings-item {\n            flex: 1;\n            text-align: center;\n            padding: 15px;\n            border-radius: 10px;\n            background: rgba(255, 255, 255, 0.05);\n        }\n        \n        .savings-item.waste {\n            border: 2px solid var(--accent-red);\n            background: rgba(255, 71, 87, 0.1);\n        }\n        \n        .savings-item.saved {\n            border: 2px solid var(--accent-green);\n            background: rgba(6, 255, 165, 0.1);\n        }\n        \n        .savings-divider {\n            width: 2px;\n            height: 60px;\n            background: rgba(255, 255, 255, 0.1);\n            margin: 0 15px;\n        }\n        \n        .savings-amount {\n            font-size: 2em;\n            font-weight: bold;\n            margin: 10px 0;\n        }\n        \n        .savings-item.waste .savings-amount {\n            color: var(--accent-red);\n        }\n        \n        .savings-item.saved .savings-amount {\n            color: var(--accent-green);\n        }\n        \n        .savings-label {\n            font-size: 0.85em;\n            color: var(--text-secondary);\n        }\n        \n        .savings-desc {\n            font-size: 0.75em;\n            color: var(--text-secondary);\n        }\n        \n        .net-savings {\n            text-align: center;\n            padding: 15px;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 10px;\n            margin-top: 10px;\n        }\n        \n        .net-amount {\n            font-size: 2em;\n            font-weight: bold;\n            color: var(--accent-teal);\n            margin: 10px 0;\n        }\n        \n        .net-percentage {\n            font-size: 1em;\n            color: var(--accent-green);\n            font-weight: 600;\n        }\n        \n        .chart-container {\n            margin-top: 20px;\n            height: 200px;\n            position: relative;\n        }\n        \n        .loading {\n            color: var(--text-secondary);\n            font-style: italic;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"card\">\n        <h3 class=\"card-title\">SMART SAVINGS MONITOR</h3>\n        <div class=\"savings-row\">\n            <div class=\"savings-item waste\">\n                <div class=\"savings-label\">Wasted Today</div>\n                <div class=\"savings-amount\" id=\"wastedAmount\" class=\"loading\">Loading...</div>\n                <div class=\"savings-desc\">Without automation</div>\n            </div>\n            <div class=\"savings-divider\"></div>\n            <div class=\"savings-item saved\">\n                <div class=\"savings-label\">Saved Today</div>\n                <div class=\"savings-amount\" id=\"savedAmount\" class=\"loading\">Loading...</div>\n                <div class=\"savings-desc\">With automation</div>\n            </div>\n        </div>\n        <div class=\"net-savings\">\n            <div class=\"net-amount\" id=\"netSavings\" class=\"loading\">Loading...</div>\n            <div class=\"net-percentage\" id=\"savingsPercentage\">Loading...</div>\n        </div>\n        <div class=\"chart-container\">\n            <canvas id=\"savingsChart\"></canvas>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n    <script>\n        console.log('=== PAGE LOADED ===');\n        \n        function formatCurrency(value) {\n            return '$' + parseFloat(value).toFixed(2);\n        }\n        \n        async function updateSavings() {\n            console.log('=== UPDATING SAVINGS ===');\n            try {\n                const response = await fetch('http://localhost:5000/api/savings');\n                console.log('Response:', response);\n                \n                if (!response.ok) {\n                    throw new Error('HTTP ' + response.status);\n                }\n                \n                const result = await response.json();\n                console.log('Data:', result);\n                \n                if (result.status !== 'success') {\n                    throw new Error('API error');\n                }\n                \n                const data = result.data;\n                console.log('Processing:', data);\n                \n                // Update display\n                document.getElementById('wastedAmount').textContent = formatCurrency(data.total_waste_cost);\n                document.getElementById('wastedAmount').classList.remove('loading');\n                \n                document.getElementById('savedAmount').textContent = formatCurrency(data.total_saved_cost);\n                document.getElementById('savedAmount').classList.remove('loading');\n                \n                document.getElementById('netSavings').textContent = formatCurrency(data.net_savings);\n                document.getElementById('netSavings').classList.remove('loading');\n                \n                const percentage = ((data.total_saved_cost) / (data.total_waste_cost + data.total_saved_cost)) * 100;\n                document.getElementById('savingsPercentage').textContent = percentage.toFixed(1) + '%';\n                \n                // Create chart\n                createSavingsChart(data.total_waste_cost, data.total_saved_cost);\n                \n            } catch (error) {\n                console.error('Error:', error);\n                document.getElementById('wastedAmount').textContent = 'ERROR';\n                document.getElementById('savedAmount').textContent = 'ERROR';\n                document.getElementById('netSavings').textContent = 'ERROR';\n            }\n        }\n        \n        function createSavingsChart(wasteCost, savedCost) {\n            const ctx = document.getElementById('savingsChart');\n            if (!ctx) return;\n            \n            new Chart(ctx, {\n                type: 'bar',\n                data: {\n                    labels: ['Without Automation', 'With Automation'],\n                    datasets: [{\n                        data: [wasteCost, savedCost],\n                        backgroundColor: ['#ff6b9d', '#06ffa5'],\n                        borderRadius: 8\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: {\n                        legend: { display: false }\n                    },\n                    scales: {\n                        y: {\n                            beginAtZero: true,\n                            ticks: {\n                                color: '#b0c4de',\n                                callback: function(value) { return '$' + value; }\n                            },\n                            grid: { color: 'rgba(255,255,255,0.1)' }\n                        },\n                        x: {\n                            ticks: { color: '#b0c4de' },\n                            grid: { display: false }\n                        }\n                    }\n                }\n            });\n        }\n        \n        // Start\n        updateSavings();\n        \n        // Refresh every 30 seconds\n        setInterval(updateSavings, 30000);\n    </script>\n</body>\n</html>",
