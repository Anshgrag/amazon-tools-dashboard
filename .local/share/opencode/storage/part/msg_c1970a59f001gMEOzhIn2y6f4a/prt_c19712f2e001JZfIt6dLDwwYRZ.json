      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Eye Infection Detection</title>\n    <link rel=\"stylesheet\" href=\"style.css\">\n    <meta name=\"description\" content=\"Preliminary eye infection detection using AI\">\n    <meta name=\"theme-color\" content=\"#2563eb\">\n</head>\n<body>\n    <div class=\"container\">\n        <header class=\"header\">\n            <h1>Eye Infection Detection</h1>\n            <p class=\"subtitle\">AI-Powered Preliminary Screening</p>\n        </header>\n\n        <main class=\"main-content\">\n            <!-- Upload Section -->\n            <section class=\"upload-section\">\n                <div class=\"upload-card\">\n                    <h2>Upload Eye Image</h2>\n                    <p class=\"upload-hint\">Select a clear, non-microscopic photograph of the eye</p>\n                    \n                    <div class=\"upload-area\" id=\"uploadArea\">\n                        <input type=\"file\" id=\"fileInput\" accept=\"image/jpeg,image/png\" hidden>\n                        <div class=\"upload-icon\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"64\" height=\"64\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                                <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect>\n                                <circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"></circle>\n                                <polyline points=\"21 15 16 10 5 21\"></polyline>\n                            </svg>\n                        </div>\n                        <p class=\"upload-text\">Tap to select or drag & drop</p>\n                        <p class=\"upload-subtext\">JPEG or PNG</p>\n                    </div>\n\n                    <!-- Image Preview -->\n                    <div class=\"preview-container\" id=\"previewContainer\" style=\"display: none;\">\n                        <div class=\"preview-header\">\n                            <h3>Image Preview</h3>\n                            <button class=\"btn-remove\" id=\"removeBtn\">Remove</button>\n                        </div>\n                        <img id=\"previewImage\" alt=\"Eye image preview\">\n                    </div>\n\n                    <!-- Analyze Button -->\n                    <button class=\"btn-analyze\" id=\"analyzeBtn\" disabled>\n                        <span class=\"btn-text\">Analyze Image</span>\n                        <span class=\"btn-loading\" style=\"display: none;\">\n                            <span class=\"spinner\"></span>\n                            Analyzing...\n                        </span>\n                    </button>\n                </div>\n            </section>\n\n            <!-- Results Section -->\n            <section class=\"results-section\" id=\"resultsSection\" style=\"display: none;\">\n                <div class=\"results-card\">\n                    <h2>Analysis Result</h2>\n                    <div class=\"result-content\" id=\"resultContent\">\n                        <div class=\"result-class\" id=\"resultClass\">Normal</div>\n                        <div class=\"result-confidence\">\n                            <span>Confidence:</span>\n                            <span id=\"confidenceScore\">95.4%</span>\n                        </div>\n                    </div>\n                    <div class=\"result-explanation\">\n                        <p id=\"resultExplanation\">\n                            The image appears to show a healthy eye with no visible signs of infection.\n                        </p>\n                    </div>\n                </div>\n            </section>\n\n            <!-- Error Section -->\n            <section class=\"error-section\" id=\"errorSection\" style=\"display: none;\">\n                <div class=\"error-card\">\n                    <div class=\"error-icon\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                            <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\n                            <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"></line>\n                            <line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"></line>\n                        </svg>\n                    </div>\n                    <h3>Error</h3>\n                    <p id=\"errorMessage\">Something went wrong. Please try again.</p>\n                    <button class=\"btn-retry\" id=\"retryBtn\">Try Again</button>\n                </div>\n            </section>\n        </main>\n\n        <!-- Disclaimer -->\n        <footer class=\"disclaimer\">\n            <div class=\"disclaimer-icon\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                    <path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\"></path>\n                    <line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\"></line>\n                    <line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"></line>\n                </svg>\n            </div>\n            <p>\n                This tool is for preliminary screening only and not a medical diagnosis.\n                Always consult an ophthalmologist for proper diagnosis and treatment.\n            </p>\n        </footer>\n    </div>\n\n    <script src=\"script.js\"></script>\n</body>\n</html>\n",
