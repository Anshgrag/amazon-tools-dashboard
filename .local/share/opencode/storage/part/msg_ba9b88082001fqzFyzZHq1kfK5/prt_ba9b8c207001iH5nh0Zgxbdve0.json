    "input": {
      "content": "<!DOCTYPE html>\n<html>\n<head>\n    <title>Savings Debug</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n</head>\n<body style=\"background: #1a2332; color: white; font-family: Arial, sans-serif;\">\n    <h1>Savings Debug Test</h1>\n    \n    <div>\n        <h3>Test Elements:</h3>\n        <p>Wasted: <span id=\"wastedAmount\">Loading...</span></p>\n        <p>Saved: <span id=\"savedAmount\">Loading...</span></p>\n        <p>Net: <span id=\"netSavings\">Loading...</span></p>\n        <p>Percentage: <span id=\"savingsPercentage\">Loading...</span></p>\n    </div>\n    \n    <div>\n        <canvas id=\"savingsChart\" width=\"400\" height=\"200\"></canvas>\n    </div>\n    \n    <div id=\"deviceSavingsList\">\n        <p>Loading devices...</p>\n    </div>\n\n    <script>\n        // Test functions\n        function formatCurrency(value) {\n            return `$${parseFloat(value).toFixed(2)}`;\n        }\n        \n        async function fetchSavingsData() {\n            try {\n                console.log('Fetching from http://localhost:5000/api/savings');\n                const response = await fetch('http://localhost:5000/api/savings');\n                console.log('Response status:', response.status);\n                \n                if (!response.ok) {\n                    throw new Error(`HTTP error! status: ${response.status}`);\n                }\n                \n                const result = await response.json();\n                console.log('Full response:', result);\n                \n                if (result.status === 'success') {\n                    updateSavingsDisplay(result.data);\n                } else {\n                    console.error('API returned error:', result);\n                }\n            } catch (error) {\n                console.error('Error:', error);\n                document.getElementById('wastedAmount').textContent = 'ERROR';\n                document.getElementById('savedAmount').textContent = 'ERROR';\n                document.getElementById('netSavings').textContent = 'ERROR';\n            }\n        }\n        \n        function updateSavingsDisplay(data) {\n            console.log('Updating with data:', data);\n            \n            // Test direct element updates\n            document.getElementById('wastedAmount').textContent = formatCurrency(data.total_waste_cost);\n            document.getElementById('savedAmount').textContent = formatCurrency(data.total_saved_cost);\n            document.getElementById('netSavings').textContent = formatCurrency(data.net_savings);\n            \n            const percentage = ((data.total_saved_cost / (data.total_waste_cost + data.total_saved_cost)) * 100).toFixed(1);\n            document.getElementById('savingsPercentage').textContent = percentage + '%';\n            \n            // Update devices\n            if (data.device_details && data.device_details.length > 0) {\n                let html = '';\n                data.device_details.forEach(device => {\n                    const net = device.saved_cost - device.waste_cost;\n                    html += `<p>${device.device_name}: ${formatCurrency(net)}</p>`;\n                });\n                document.getElementById('deviceSavingsList').innerHTML = html;\n            }\n            \n            // Create chart\n            createSavingsChart(data.total_waste_cost, data.total_saved_cost);\n        }\n        \n        function createSavingsChart(wasteCost, savedCost) {\n            const ctx = document.getElementById('savingsChart');\n            if (!ctx) return;\n            \n            new Chart(ctx, {\n                type: 'bar',\n                data: {\n                    labels: ['Without Automation', 'With Automation'],\n                    datasets: [{\n                        data: [wasteCost, savedCost],\n                        backgroundColor: ['#ff6b9d', '#06ffa5'],\n                        borderRadius: 8\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    plugins: {\n                        legend: { display: false }\n                    },\n                    scales: {\n                        y: {\n                            beginAtZero: true,\n                            ticks: {\n                                color: 'white',\n                                callback: function(value) { return '$' + value; }\n                            },\n                            grid: { color: 'rgba(255,255,255,0.1)' }\n                        },\n                        x: {\n                            ticks: { color: 'white' },\n                            grid: { display: false }\n                        }\n                    }\n                }\n            });\n        }\n        \n        // Start\n        fetchSavingsData();\n    </script>\n</body>\n</html>",
